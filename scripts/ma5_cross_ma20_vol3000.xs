// ============================================================
// 策略：5日均線向上突破20日均線（黃金交叉）+ 成交量 > 3000張
// 腳本類型：選股腳本 (Scanner)
// ============================================================

// 確保讀取足夠的歷史 K 棒（至少需要 20 根計算 MA20）
SetTotalBar(30);

// ── 變數宣告（無底線、無 daily）──────────────────────────────
Var: ma5(0), ma20(0);

// ── 計算技術指標 ─────────────────────────────────────────────
ma5  = Average(Close, 5);   // 5日收盤均線
ma20 = Average(Close, 20);  // 20日收盤均線

// ── 篩選條件 ─────────────────────────────────────────────────
// 條件一：5日均線「今日」向上突破20日均線（黃金交叉）
//         CrossOver 確保昨日 ma5 <= ma20，今日 ma5 > ma20
Condition1 = CrossOver(ma5, ma20);

// 條件二：當日成交量 > 3000張（排除低量假突破）
Condition2 = Volume > 3000;

// ── 觸發選股 + 輸出欄位 ──────────────────────────────────────
if Condition1 and Condition2 then
begin
    ret = 1;
    OutputField(1, ma5, 2, "MA5");            // 欄位1：5日均線價格
    OutputField(2, ma20, 2, "MA20");           // 欄位2：20日均線價格
    OutputField(3, ma5 - ma20, 2, "均線差");   // 欄位3：兩線差值（正值代表剛突破）
    OutputField(4, Volume, 0, "成交量(張)");   // 欄位4：當日成交量
end;
